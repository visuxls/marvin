OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=z-ai/glm-5.2
# Comma-separated models for the UI selector (optional).
# Use label:model-id for custom names, e.g. GLM:z-ai/glm-5.2,Claude:anthropic/claude-sonnet-4
# OPENROUTER_MODELS=z-ai/glm-5.2,anthropic/claude-sonnet-4
OPENROUTER_PROVIDER_ORDER=deepinfra
OPENROUTER_ALLOW_FALLBACKS=true

DB_PATH=data/marvin.db
IMPORTS_DIR=data/imports
PROFILE_PATH=data/profile.txt
AUTO_IMPORT_ON_STARTUP=true

# Comma-separated origins for the Next.js dev server (optional)
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
