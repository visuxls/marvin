# Backend URL for the Next.js dev proxy (server-side only).
# The browser calls /api/* on localhost:3000; Next.js forwards to Marvin.
MARVIN_API_URL=http://127.0.0.1:7932

# Optional: call Marvin directly from the browser instead of the proxy.
# Leave unset in normal development.
# NEXT_PUBLIC_MARVIN_API_URL=http://127.0.0.1:7932
